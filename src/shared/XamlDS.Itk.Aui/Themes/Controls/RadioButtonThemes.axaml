<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ControlTheme x:Key="ItkRadioButtonBaseTheme" TargetType="RadioButton">
		<Setter Property="FontFamily" Value="{StaticResource GlobalFontFamily}"/>
		<Setter Property="FontSize" Value="13"/>
		<Setter Property="FontWeight" Value="Medium"/>

		<Setter Property="Background" Value="{StaticResource Bg0Brush}"/>
		<Setter Property="Foreground" Value="{StaticResource Fg0Brush}"/>
		<Setter Property="BorderBrush" Value="{StaticResource Fg0Brush}"/>

		<Setter Property="Margin" Value="3"/>
		<Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
		<Setter Property="HorizontalContentAlignment" Value="Center"/>
		<Setter Property="VerticalContentAlignment" Value="Center"/>

		<Setter Property="Template">
			<ControlTemplate>
				<Grid Margin="{TemplateBinding Margin}">
					<Border x:Name="PART_Bg" Background="{TemplateBinding BorderBrush}" CornerRadius="{TemplateBinding CornerRadius}" Opacity="0.15"/>
					<Border x:Name="PART_checkBar" Background="{TemplateBinding BorderBrush}" CornerRadius="2" Margin="3" MinHeight="4" MinWidth="4"/>
					<ContentPresenter x:Name="PART_content" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Content="{TemplateBinding Content}" Margin="{TemplateBinding Padding}"/>
				</Grid>
			</ControlTemplate>
		</Setter>

		<Style Selector="^:disabled">
			<Setter Property="Opacity" Value="0.2"/>
		</Style>
		<Style Selector="^:pointerover">
			<Style Selector="^ /template/ Border#PART_Bg">
				<Setter Property="Opacity" Value="0.3"/>
			</Style>
		</Style>
		<Style Selector="^:checked">
			<Setter Property="Foreground" Value="{StaticResource Bg0Brush}"/>
			<Style Selector="^ /template/ Border#PART_Bg">
				<Setter Property="Opacity" Value="0.9"/>
			</Style>
			<Style Selector="^ /template/ Border#PART_checkBar">
				<Setter Property="Background" Value="{StaticResource Bg0Brush}"/>
			</Style>
		</Style>
	</ControlTheme>

	<ControlTheme x:Key="ItkRadioButtonTopDownTheme" TargetType="RadioButton" BasedOn="{StaticResource ItkRadioButtonBaseTheme}">
		<Setter Property="Padding" Value="8,6,8,10"/>
		<Style Selector="^ /template/ Border#PART_checkBar">
			<Setter Property="VerticalAlignment" Value="Bottom"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
		</Style>

		<Style Selector="^:checked">
			<Setter Property="Padding" Value="8,10,8,6"/>
			<Style Selector="^ /template/ Border#PART_checkBar">
				<Setter Property="VerticalAlignment" Value="Top"/>
			</Style>
		</Style>
	</ControlTheme>

	<ControlTheme x:Key="ItkRadioButtonLeftRightTheme" TargetType="RadioButton" BasedOn="{StaticResource ItkRadioButtonBaseTheme}">
		<Setter Property="Padding" Value="18,8,12,8"/>
		<Setter Property="HorizontalContentAlignment" Value="Right"/>
		<Style Selector="^ /template/ Border#PART_checkBar">
			<Setter Property="VerticalAlignment" Value="Stretch"/>
			<Setter Property="HorizontalAlignment" Value="Left"/>
		</Style>

		<Style Selector="^:checked">
			<Setter Property="Padding" Value="12,8,18,8"/>
			<Setter Property="HorizontalContentAlignment" Value="Left"/>
			<Style Selector="^ /template/ Border#PART_checkBar">
				<Setter Property="VerticalAlignment" Value="Stretch"/>
				<Setter Property="HorizontalAlignment" Value="Right"/>
			</Style>
		</Style>
	</ControlTheme>
</ResourceDictionary>
