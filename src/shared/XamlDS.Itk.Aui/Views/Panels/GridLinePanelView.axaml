<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:XamlDS.Itk">
 
  <ControlTheme x:Key="{x:Type controls:GridLinePanelView}" TargetType="controls:GridLinePanelView">
    <Setter Property="Template">
      <ControlTemplate>
        <TextBlock Text="Templated Control" />
      </ControlTemplate>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
