<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:controls="using:XamlDS.Itk.Views.Panes">

	<ControlTheme x:Key="{x:Type controls:ContentPaneView}" TargetType="controls:ContentPaneView">
		<Setter Property="Template">
			<ControlTemplate>
				<ContentControl Content="{Binding Content}"/>
			</ControlTemplate>
		</Setter>
	</ControlTheme>

</ResourceDictionary>
