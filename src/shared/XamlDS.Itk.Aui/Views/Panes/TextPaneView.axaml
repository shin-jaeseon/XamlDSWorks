<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:controls="using:XamlDS.Itk.Views.Panes">

	<ControlTheme x:Key="{x:Type controls:TextPaneView}" TargetType="controls:TextPaneView">
		<Setter Property="Text" Value="{Binding Text}"/>
		<Setter Property="Template">
			<ControlTemplate>
				<TextBlock Name="PART_TextBlock" 
						   Text="{TemplateBinding Text}" HorizontalAlignment="Center" VerticalAlignment="Center"
						   TextWrapping="Wrap" />
			</ControlTemplate>
		</Setter>
	</ControlTheme>
</ResourceDictionary>
