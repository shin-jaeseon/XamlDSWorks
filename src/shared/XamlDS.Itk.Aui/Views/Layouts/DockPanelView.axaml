<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:controls="using:XamlDS.Itk.Views.Layouts">

	<ControlTheme x:Key="{x:Type controls:DockPanelView}" TargetType="controls:DockPanelView">
		<Setter Property="Width" Value="{Binding Width}"/>
		<Setter Property="Height" Value="{Binding Height}"/>
		<Setter Property="Template">
			<ControlTemplate>
				<DockPanel Name="PART_DockPanel" LastChildFill="True"/>
			</ControlTemplate>
		</Setter>
	</ControlTheme>
</ResourceDictionary>
