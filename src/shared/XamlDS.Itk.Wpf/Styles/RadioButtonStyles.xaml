<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ControlTemplate x:Key="ItkRadioGroupBoxTemplate" TargetType="{x:Type ContentControl}">
        <Grid>
            <Border BorderBrush="#F000" CornerRadius="7" Opacity="0.4" BorderThickness="1"/>
            <Border Background="#F000" CornerRadius="6" Margin="1" Opacity="0.2"/>
            <Border BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="4" Margin="2" Opacity="0.2" BorderThickness="3"/>
            <Border BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="6" Margin="1" BorderThickness="1"/>
            <ContentPresenter x:Name="PART_Content" Margin="3"
                  Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"/>
        </Grid>
    </ControlTemplate>

    <Style x:Key="RadioGroupStyle" TargetType="{x:Type ContentControl}">
        <Setter Property="Template" Value="{StaticResource ItkRadioGroupBoxTemplate}"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="BorderBrush" Value="#FFFF"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextBlock.LineHeight" Value="14"/>
        <Setter Property="TextBlock.LineStackingStrategy" Value="BlockLineHeight"/>
    </Style>

    <ControlTemplate x:Key="ItkRadioButtonHTemplate" TargetType="{x:Type RadioButton}">
        <Grid>
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                </Style>
            </Grid.Resources>
            <Border x:Name="PART_BG" Background="{TemplateBinding BorderBrush}" CornerRadius="3" Opacity="0.1" Margin="1" />
            <Border BorderBrush="#F000" CornerRadius="3" Opacity="0.4" BorderThickness="1"/>
            <Border BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="1" Margin="1" Opacity="0.05" BorderThickness="3"/>
            <Border x:Name="PART_ColorBar" Background="{TemplateBinding BorderBrush}" CornerRadius="2" Opacity="1.0" Margin="4" Height="4"
                    HorizontalAlignment="Stretch" VerticalAlignment="Bottom"/>
            <ContentPresenter x:Name="PART_Content" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12"
                              Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_BG" Property="Opacity" Value="0.25"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PART_BG" Property="Opacity" Value="0.5"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.2"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="PART_BG" Property="Opacity" Value="0.8"/>
                <Setter TargetName="PART_ColorBar" Property="Background" Value="#F000"/>
                <Setter TargetName="PART_ColorBar" Property="VerticalAlignment" Value="Top"/>
                <Setter Property="Foreground" Value="#F000"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="ItkRadioButtonVTemplate" TargetType="{x:Type RadioButton}">
        <Grid x:Name="PART_Root">
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                </Style>
            </Grid.Resources>
            <Border x:Name="PART_BG" Background="{TemplateBinding BorderBrush}" Margin="1" CornerRadius="3" Opacity="0.1"/>
            <Border BorderBrush="#F000" CornerRadius="3" Opacity="0.4" BorderThickness="1"/>
            <Border BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="1" Margin="1" Opacity="0.05" BorderThickness="3"/>
            <Border x:Name="PART_ColorBar" Background="{TemplateBinding BorderBrush}" CornerRadius="2" Opacity="1.0" Margin="4" Width="6"
                HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
            <ContentPresenter x:Name="PART_Content" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16,12"
                          Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_BG" Property="Opacity" Value="0.25"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="PART_BG" Property="Opacity" Value="0.5"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.25"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="PART_BG" Property="Opacity" Value="0.8"/>
                <Setter TargetName="PART_ColorBar" Property="Background" Value="#F000"/>
                <Setter TargetName="PART_ColorBar" Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Foreground" Value="#F000"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="ItkRadioButtonBaseStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="Background" Value="#000"/>
        <Setter Property="BorderBrush" Value="#FFFF"/>
        <Setter Property="Foreground" Value="#FFFF"/>
        <Setter Property="Margin" Value="3"/>
    </Style>

    <Style x:Key="ItkRadioButtonHStyle" TargetType="{x:Type RadioButton}" BasedOn="{StaticResource ItkRadioButtonBaseStyle}">
        <Setter Property="Template" Value="{StaticResource ItkRadioButtonHTemplate}"/>
    </Style>

    <Style x:Key="ItkRadioButtonVStyle" TargetType="{x:Type RadioButton}"  BasedOn="{StaticResource ItkRadioButtonBaseStyle}">
        <Setter Property="Template" Value="{StaticResource ItkRadioButtonVTemplate}"/>
    </Style>

</ResourceDictionary>
