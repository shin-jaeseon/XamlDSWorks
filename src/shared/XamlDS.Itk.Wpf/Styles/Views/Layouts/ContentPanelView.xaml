<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:XamlDS.Itk"
                    xmlns:layouts="clr-namespace:XamlDS.Itk.Views.Layouts">

    <Style TargetType="{x:Type layouts:ContentPanelView}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type layouts:ContentPanelView}">
                    <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentControl Content="{Binding Content}" Margin="{TemplateBinding Margin}"
                                        ContentTemplateSelector="{x:Static local:ItkTemplateSelector.Instance}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>
