<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:layouts="clr-namespace:XamlDS.Itk.Views.Layouts">

    <!-- DockPanelView Default Style -->
    <Style TargetType="{x:Type layouts:DockPanelView}">
        <Setter Property="Width" Value="{Binding Width}"/>
        <Setter Property="Height" Value="{Binding Height}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type layouts:DockPanelView}">
                    <DockPanel x:Name="PART_DockPanel" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
