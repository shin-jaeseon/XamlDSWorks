<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:XamlDS.Itk.Converters"
                    xmlns:layouts="clr-namespace:XamlDS.Itk.Views.Layouts">

    <Style TargetType="{x:Type layouts:StackPanelView}">
        <Style.Resources>
            <converters:ItkOrientationToOrientation x:Key="OrientationConverter"/>
        </Style.Resources>
        <Setter Property="Width" Value="{Binding Width}"/>
        <Setter Property="Height" Value="{Binding Height}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type layouts:StackPanelView}">
                    <StackPanel Name="PART_StackPanel" Orientation="{Binding Orientation, Converter={StaticResource OrientationConverter}}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
