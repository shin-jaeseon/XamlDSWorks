<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="clr-namespace:XamlDS.Itk.Views">

    <!-- ViewPresenter now inherits from Decorator, not ContentControl -->
    <Style TargetType="{x:Type views:ViewPresenter}">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <!-- No Template needed - Decorator handles Child rendering automatically -->
    </Style>

</ResourceDictionary>
