<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:vm="using:LayoutWork.ViewModels"
		xmlns:itk="http://xamldesignstudio.com"
		mc:Ignorable="d" Width="1600" Height="960" MinHeight="720" MinWidth="1200"
		x:DataType="vm:AppWindowVm"
		x:Class="LayoutWork.Aui.Views.AppWindowView"
		Title="AppWindowView">

	<ContentControl Content="{Binding}"/>

</Window>
