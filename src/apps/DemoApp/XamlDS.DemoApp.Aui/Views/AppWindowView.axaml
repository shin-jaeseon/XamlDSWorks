<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:XamlDS.DemoApp.Views"
		xmlns:viewmodels="using:XamlDS.DemoApp.ViewModels"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		x:Class="XamlDS.DemoApp.Views.AppWindowView"
		x:DataType="viewmodels:AppWindowVm"
		Width="1600" Height="960" MinHeight="720" MinWidth="1200"
		Title="XamlDS Avalonia UI Demo">

	<DockPanel Classes="BodyPanel">
		<local:AppBottomBarView DataContext="{Binding AppBottomBar}" DockPanel.Dock="Bottom"/>
		<ContentControl Content="{Binding AppMainPanel.CurrentPanel}"/>
	</DockPanel>

</Window>
