<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XamlDS.Itk.Converters;assembly=XamlDS.Itk.Aui"
             x:Class="XamlDS.DemoApp.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://XamlDS.Itk.Aui/Converters/ItkConverters.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://XamlDS.Itk.Aui/Styles/ItkDarkStyles.axaml"/>
    </Application.Styles>
</Application>
