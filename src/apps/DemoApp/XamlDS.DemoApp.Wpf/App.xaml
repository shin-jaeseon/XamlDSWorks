<Application x:Class="XamlDS.DemoApp.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:XamlDS.Itk.Converters;assembly=XamlDS.Itk.Wpf"
             xmlns:local="clr-namespace:XamlDS.DemoApp.Wpf">

    <Application.Resources>
        <ResourceDictionary>
            <converters:TypeNameToIsCheckedConverter x:Key="TypeNameConverter"/>
            <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
                <ResourceDictionary Source="pack://application:,,,/XamlDS.Itk.Wpf;component/Themes/ItkDark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
