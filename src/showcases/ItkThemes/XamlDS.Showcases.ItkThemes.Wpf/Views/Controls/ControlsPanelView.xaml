<UserControl x:Class="XamlDS.Showcases.ItkThemes.Views.Controls.ControlsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:itk="http://xamldesignstudio.com"
             xmlns:local="clr-namespace:XamlDS.Showcases.ItkThemes.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Border Style="{StaticResource BodyPanelStyle}" Background="#F444">
        <DockPanel>
            <ContentControl Grid.Column="1" HorizontalAlignment="Center" Style="{StaticResource RadioGroupStyle}" DockPanel.Dock="Left" VerticalAlignment="Center">
                <StackPanel Orientation="Vertical">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource ItkRadioButtonVStyle}">
                            <!--<Setter Property="MinWidth" Value="128"/>-->
                        </Style>
                    </StackPanel.Resources>
                    <RadioButton GroupName="ControlsPanelGroup" Content="BUTTONS" IsChecked="{Binding CurrentPanelName, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Buttons}" />
                    <RadioButton GroupName="ControlsPanelGroup" Content="CHECKBOXS" IsChecked="{Binding CurrentPanelName, Converter={StaticResource StringToBoolConverter}, ConverterParameter=CheckBoxs}"/>
                    <RadioButton GroupName="ControlsPanelGroup" Content="RADIOBUTTONS" IsChecked="{Binding CurrentPanelName, Converter={StaticResource StringToBoolConverter}, ConverterParameter=RadioButtons}"/>
                    <RadioButton GroupName="ControlsPanelGroup" Content="SLIDERS" IsChecked="{Binding CurrentPanelName, Converter={StaticResource StringToBoolConverter}, ConverterParameter=Sliders}"/>
                    <RadioButton GroupName="ControlsPanelGroup" Content="TEXTBOXS" IsChecked="{Binding CurrentPanelName, Converter={StaticResource StringToBoolConverter}, ConverterParameter=TextBoxs}" BorderBrush="{DynamicResource AccentBBrush}"/>
                    <Rectangle Height="12"/>
                    <RadioButton GroupName="ControlsPanelGroup" Content="NUMERIC" BorderBrush="Orange" IsEnabled="False"/>
                    <RadioButton GroupName="ControlsPanelGroup" Content="INPUT" BorderBrush="Orange" IsEnabled="False"/>
                    <Rectangle Height="12"/>
                    <RadioButton GroupName="ControlsPanelGroup" Content="GAGE 1" BorderBrush="HotPink" IsEnabled="False"/>
                    <RadioButton GroupName="ControlsPanelGroup" Content="GAGE 2" BorderBrush="HotPink" IsEnabled="False"/>
                </StackPanel>
            </ContentControl>
            <ContentControl Content="{Binding CurrentPanel}"/>
        </DockPanel>
    </Border>

</UserControl>
