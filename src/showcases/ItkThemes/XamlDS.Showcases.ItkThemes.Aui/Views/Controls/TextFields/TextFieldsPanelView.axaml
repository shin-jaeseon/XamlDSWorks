<UserControl xmlns="https://github.com/avaloniaui"
						 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
						 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
						 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
						 xmlns:itk="http://xamldesignstudio.com"
						 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
						 x:Class="XamlDS.Showcases.ItkThemes.Views.Controls.TextFields.TextFieldsPanelView">

	<Border Classes="BodyPanel Bg1">
		<Border HorizontalAlignment="Center" VerticalAlignment="Center" Classes="BodyPanel Bg2" Padding="3">
			<StackPanel>
				<itk:TextField Label="Weight" Value="10.4" Suffix="Kg"/>
				<itk:TextField Label="Height" Value="2.4" Suffix="m"/>
				<itk:TextField Label="Width" Value="1.4" Suffix="m"/>
				<itk:TextField Label="Status" Value="한글폰트 테스트" Suffix="(Active)" ValueWidth="120"/>
			</StackPanel>
		</Border>
	</Border>

</UserControl>
