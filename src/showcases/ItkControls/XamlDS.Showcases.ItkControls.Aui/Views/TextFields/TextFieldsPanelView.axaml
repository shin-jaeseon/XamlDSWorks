<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:itk="http://xamldesignstudio.com"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="XamlDS.Showcases.ItkControls.Views.TextFields.TextFieldsPanelView">

	<Border Classes="BodyPanel Bg1">
		<ScrollViewer>
			<Grid>
				<itk:GridLinePane GridOpacity="0.05" GridSpacing="48" Margin="4" />
				<StackPanel>
					<Border Width="960" Height="194" Margin="24,48,24,24">
						<StackPanel VerticalAlignment="Bottom">
							<StackPanel Orientation="Horizontal" Margin="0,0,0,12">
								<TextBlock Text="TextField" FontSize="32" FontWeight="Bold"/>
								<TextBlock Text="XamlDS.Itk.Controls.TextField" Margin="8,0,0,4" FontWeight="Bold" Opacity="0.75" Foreground="{DynamicResource AccentABrush}" VerticalAlignment="Bottom" />
							</StackPanel>
							<TextBlock TextWrapping="Wrap" FontSize="16" Opacity="0.75"
									   Text="TextField is a flexible display control for showing formatted text values with optional labels, prefixes, and suffixes. It's designed to display read-only data in a consistent, professional format across your application." />
						</StackPanel>
					</Border>
					<Border Width="960" Height="480" Background="#2888" Margin="24">
						<StackPanel Orientation="Horizontal">
							<Border Width="288" HorizontalAlignment="Left" Background="#4888" VerticalAlignment="Top" DataContext="{Binding PowerGeneratorPane}"
									Margin="48,48,48,0" Padding="8">
								<StackPanel>
									<StackPanel.Styles>
										<Style Selector="itk|TextField">
											<Setter Property="LabelWidth" Value="110" />
											<Setter Property="SuffixWidth" Value="34" />
										</Style>
									</StackPanel.Styles>

									<!-- ELECTRICAL Section -->
									<TextBlock Text="ELECTRICAL" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
									<itk:TextField Label="Output Voltage" Value="{Binding OutputVoltage}" Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding VoltageStatus}" Prefix="L1-L2" Suffix="V"
												   NumberFormat="F1" />
									<itk:TextField Label="Output Current" Value="{Binding OutputCurrent}" Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding CurrentStatus}" Prefix="L1" Suffix="A"
												   NumberFormat="F1" />
									<itk:TextField Label="Frequency" Value="{Binding Frequency}"
												   Status="{Binding FrequencyStatus}" Suffix="Hz" NumberFormat="F2" />
									<itk:TextField Label="Active Power" Value="{Binding ActivePower}" Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding ActivePowerStatus}" Suffix="kW" NumberFormat="F1" />
									<itk:TextField Label="Reactive Power" Value="{Binding ReactivePower}"
												   Status="{Binding ReactivePowerStatus}" Suffix="kVAr" NumberFormat="F1" />

									<!-- ENGINE Section -->
									<TextBlock Text="ENGINE" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
									<itk:TextField Label="Engine Speed" Value="{Binding EngineSpeed}" Foreground="{DynamicResource AccentBBrush}"
												   Status="{Binding EngineSpeedStatus}" Suffix="RPM" NumberFormat="F0" />
									<itk:TextField Label="Engine Temperature" Value="{Binding EngineTemperature}" Foreground="{DynamicResource AccentBBrush}"
												   Status="{Binding EngineTemperatureStatus}" Prefix="Coolant" Suffix="°C"
												   NumberFormat="F1" />
									<itk:TextField Label="Oil Pressure" Value="{Binding OilPressure}"
												   Status="{Binding OilPressureStatus}" Suffix="bar" NumberFormat="F1" />

									<!-- STATUS Section -->
									<TextBlock Text="STATUS" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
									<itk:TextField Label="Fuel Level" Value="{Binding FuelLevel}"
												   Status="{Binding FuelLevelStatus}" Suffix="%" NumberFormat="F1" />
									<itk:TextField Label="Running Hours" Value="{Binding RunningHours}" Suffix="hrs"
												   NumberFormat="F1" />
								</StackPanel>
							</Border>

						</StackPanel>
					</Border>
					<Border Width="960" Height="432" Background="#2888" Margin="24">
						<Border Width="480" HorizontalAlignment="Left" Background="#4888" VerticalAlignment="Top" Margin="48" Padding="8" DataContext="{Binding PowerGeneratorPane}">
							<StackPanel>
								<!-- ELECTRICAL Section -->
								<TextBlock Text="ELECTRICAL" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
								<WrapPanel>
									<itk:TextField Label="Output Voltage" Value="{Binding OutputVoltage}" Classes="VerticalX2"  Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding VoltageStatus}" Prefix="L1-L2" Suffix="V"
												   NumberFormat="F1" />
									<itk:TextField Label="Output Current" Value="{Binding OutputCurrent}" Classes="VerticalX2"  Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding CurrentStatus}" Prefix="L1" Suffix="A"
												   NumberFormat="F1" />
									<itk:TextField Label="Frequency" Value="{Binding Frequency}" Classes="VerticalX2"
												   Status="{Binding FrequencyStatus}" Suffix="Hz" NumberFormat="F2" />
									<itk:TextField Label="Active Power" Value="{Binding ActivePower}" Classes="VerticalX2" Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding ActivePowerStatus}" Suffix="kW" NumberFormat="F1" />
									<itk:TextField Label="Reactive Power" Value="{Binding ReactivePower}" Classes="VerticalX2"
												   Status="{Binding ReactivePowerStatus}" Suffix="kVAr" NumberFormat="F1" />
								</WrapPanel>

								<!-- ENGINE Section -->
								<TextBlock Text="ENGINE" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
								<WrapPanel>
									<itk:TextField Label="Engine Speed" Value="{Binding EngineSpeed}" Classes="VerticalX2" Foreground="{DynamicResource AccentBBrush}"
												   Status="{Binding EngineSpeedStatus}" Suffix="RPM" NumberFormat="F0" />
									<itk:TextField Label="Engine Temp" Value="{Binding EngineTemperature}" Classes="VerticalX2" Foreground="{DynamicResource AccentBBrush}"
												   Status="{Binding EngineTemperatureStatus}" Prefix="Coolant" Suffix="°C"
												   NumberFormat="F1" />
									<itk:TextField Label="Oil Pressure" Value="{Binding OilPressure}" Classes="VerticalX2"
												   Status="{Binding OilPressureStatus}" Suffix="bar" NumberFormat="F1" />
								</WrapPanel>

								<!-- STATUS Section -->
								<TextBlock Text="STATUS" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
								<WrapPanel>
									<itk:TextField Label="Fuel Level" Value="{Binding FuelLevel}" Classes="VerticalX2"
												   Status="{Binding FuelLevelStatus}" Suffix="%" NumberFormat="F1" />
									<itk:TextField Label="Running Hours" Value="{Binding RunningHours}" Suffix="hrs" Classes="VerticalX2"
												   NumberFormat="F1" />
								</WrapPanel>
							</StackPanel>
						</Border>
					</Border>
					<Border Width="960" Height="528" Background="#2888" Margin="24,24,24,96">
						<Border Width="720" HorizontalAlignment="Left" Background="#4888" VerticalAlignment="Top" Margin="48" Padding="8" DataContext="{Binding PowerGeneratorPane}">
							<StackPanel>
								<!-- ELECTRICAL Section -->
								<TextBlock Text="ELECTRICAL" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
								<WrapPanel>
									<itk:TextField Label="Output Voltage" Value="{Binding OutputVoltage}" Classes="VerticalX4"  Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding VoltageStatus}" Prefix="L1-L2" Suffix="V" NumberFormat="F1" />
									<itk:TextField Label="Output Current" Value="{Binding OutputCurrent}" Classes="VerticalX4"  Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding CurrentStatus}" Prefix="L1" Suffix="A" NumberFormat="F1" />
									<itk:TextField Label="Frequency" Value="{Binding Frequency}" Classes="VerticalX4"
												   Status="{Binding FrequencyStatus}" Suffix="Hz" NumberFormat="F2" />
									<itk:TextField Label="Active Power" Value="{Binding ActivePower}" Classes="VerticalX4" Foreground="{DynamicResource AccentABrush}"
												   Status="{Binding ActivePowerStatus}" Suffix="kW" NumberFormat="F1" />
									<itk:TextField Label="Reactive Power" Value="{Binding ReactivePower}" Classes="VerticalX4"
												   Status="{Binding ReactivePowerStatus}" Suffix="kVAr" NumberFormat="F1" />
								</WrapPanel>

								<!-- ENGINE Section -->
								<TextBlock Text="ENGINE" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
								<WrapPanel>
									<itk:TextField Label="Engine Speed" Value="{Binding EngineSpeed}" Classes="VerticalX4" Foreground="{DynamicResource AccentBBrush}"
												   Status="{Binding EngineSpeedStatus}" Suffix="RPM" NumberFormat="F0" />
									<itk:TextField Label="Engine Temp" Value="{Binding EngineTemperature}" Classes="VerticalX4" Foreground="{DynamicResource AccentBBrush}"
												   Status="{Binding EngineTemperatureStatus}" Prefix="Coolant" Suffix="°C"
												   NumberFormat="F1" />
									<itk:TextField Label="Oil Pressure" Value="{Binding OilPressure}" Classes="VerticalX4"
												   Status="{Binding OilPressureStatus}" Suffix="bar" NumberFormat="F1" />
								</WrapPanel>

								<!-- STATUS Section -->
								<TextBlock Text="STATUS" FontSize="11" FontWeight="SemiBold" Opacity="0.5" Margin="3" />
								<WrapPanel>
									<itk:TextField Label="Fuel Level" Value="{Binding FuelLevel}" Classes="VerticalX4"
												   Status="{Binding FuelLevelStatus}" Suffix="%" NumberFormat="F1" />
									<itk:TextField Label="Running Hours" Value="{Binding RunningHours}" Suffix="hrs" Classes="VerticalX4" NumberFormat="F1" />
								</WrapPanel>
							</StackPanel>
						</Border>
					</Border>
				</StackPanel>
			</Grid>
		</ScrollViewer>
	</Border>
</UserControl>
